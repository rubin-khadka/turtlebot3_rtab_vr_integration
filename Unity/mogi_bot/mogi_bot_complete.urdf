<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    Unity-Compatible URDF for mogi_bot                                          | -->
<!-- |    Modified from xacro output - mesh paths updated for Unity                   | -->
<!-- =================================================================================== -->
<robot name="mogi_bot">
  
  <!-- ========== MATERIAL DEFINITIONS ========== -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.4235294117647059 0.0392156862745098 1.0"/>
  </material>
  <material name="brown">
    <color rgba="0.8705882352941177 0.8117647058823529 0.7647058823529411 1.0"/>
  </material>

  <!-- ========== ROBOT CHASSIS ========== -->
  <link name="base_footprint"/>
  
  <joint name="base_footprint_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>
  
  <link name="base_link">
    <pose>0 0 0.1 0 0 0</pose>
    <inertial>
      <mass value="15.0"/>
      <origin rpy="0 0 0" xyz="0.0 0 0"/>
      <inertia ixx="0.0625" ixy="0" ixz="0" iyy="0.2125" iyz="0" izz="0.25"/>
    </inertial>
    <collision name="collision">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size=".4 .2 .1"/>
      </geometry>
    </collision>
    <visual name="base_link_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- UPDATED: Changed from package:// to relative path -->
        <mesh filename="meshes/mogi_bot.dae"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision name="rear_caster_collision">
      <origin rpy="0 0 0" xyz="-0.15 0 -0.05"/>
      <geometry>
        <sphere radius="0.0499"/>
      </geometry>
    </collision>
    <visual name="rear_caster_visual">
      <origin rpy="0 0 0" xyz="-0.15 0 -0.05"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision name="front_caster_collision">
      <origin rpy="0 0 0" xyz="0.15 0 -0.05"/>
      <geometry>
        <sphere radius="0.0499"/>
      </geometry>
    </collision>
    <visual name="front_caster_visual">
      <origin rpy="0 0 0" xyz="0.15 0 -0.05"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- ========== WHEELS ========== -->
  <joint name="left_wheel_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0.15 0"/>
    <child link="left_wheel"/>
    <parent link="base_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>
  
  <link name="left_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <inertia ixx="0.014" ixy="0" ixz="0" iyy="0.014" iyz="0" izz="0.025"/>
    </inertial>
    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length=".05" radius=".1"/>
      </geometry>
    </collision>
    <visual name="left_wheel_visual">
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <!-- UPDATED: Changed from package:// to relative path -->
        <mesh filename="meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 -0.15 0"/>
    <child link="right_wheel"/>
    <parent link="base_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>
  
  <link name="right_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <inertia ixx="0.014" ixy="0" ixz="0" iyy="0.014" iyz="0" izz="0.025"/>
    </inertial>
    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length=".05" radius=".1"/>
      </geometry>
    </collision>
    <visual name="right_wheel_visual">
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <!-- UPDATED: Changed from package:// to relative path -->
        <mesh filename="meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- ========== CAMERA ========== -->
  <joint name="camera_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.225 0 0.075"/>
    <child link="camera_link"/>
    <parent link="base_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <link name="camera_link">
    <pose>0 0 0 0 0 0</pose>
    <inertial>
      <mass value="0.1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <collision name="collision">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size=".03 .03 .03"/>
      </geometry>
    </collision>
    <visual name="camera_link_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size=".03 .03 .03"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <origin rpy="-1.5707 0 -1.5707" xyz="0 0 0"/>
    <child link="camera_link_optical"/>
    <parent link="camera_link"/>
  </joint>
  
  <link name="camera_link_optical"/>

  <!-- ========== IMU ========== -->
  <joint name="imu_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>
  
  <link name="imu_link"/>

  <!-- ========== LIDAR ========== -->
  <joint name="scan_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 0 0.15"/>
    <child link="scan_link"/>
    <parent link="base_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>
  
  <link name="scan_link">
    <inertial>
      <mass value="1e-5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <collision name="collision">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size=".1 .1 .1"/>
      </geometry>
    </collision>
    <visual name="scan_link_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- UPDATED: Changed from package:// to relative path -->
        <mesh filename="meshes/lidar.dae"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- ========== GAZEBO TAGS (Unity will ignore these, but keep for reference) ========== -->
  <gazebo reference="left_wheel">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="right_wheel">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="base_link">
    <mu1>0.000002</mu1>
    <mu2>0.000002</mu2>
  </gazebo>
  
  <gazebo reference="camera_link">
    <material>Gazebo/Red</material>
  </gazebo>
  
  <gazebo reference="scan_link">
    <selfCollide>false</selfCollide>
    <mu1 value="0.05"/>
    <mu2 value="0.05"/>
  </gazebo>

</robot>